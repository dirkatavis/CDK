# Global file extensions (Ignore all logs, text outputs, and temporary files)
*.tmp
*.log
*.txt
!**/tests/fixtures/*.txt
*.bak
*.old
*~
*.zsn
scanner_checkpoint.tmp
Thumbs.db

# Directory-level ignores
**/test_artifacts/
Temp/
runtime/logs/
runtime/data/out/

# CSV data files (Assume-unchanged will be applied to tracked CSVs separately)
# We only ignore CSVs that should NEVER be tracked.
*._*
# (Any CSV that is NOT tracked but generated should be ignored)
apps/**/*_out.csv
ValidateRoList_OUT.csv

# Legacy ignores (kept for backward compatibility with older checkouts)
Close_ROs/
Maintenance_RO_Closer/RO_Status_Report.csv
Maintenance_RO_Closer/exception_list.csv
Maintenance_RO_Closer/coordinate_check.txt

# Ignore ValidateRoList runtime artifacts and test outputs
# (Old paths)
tools/ValidateRoList/*.log
tools/ValidateRoList/*_out.txt
tools/ValidateRoList/*_mock_*.txt
tools/ValidateRoList/ValidateRoList_IN.csv

# New local test artifact folders
**/test_artifacts/

# Local app outputs/logs
apps/**/*.log
apps/**/*_out.csv
apps/post_final_charges/Pfc_Summary_output.csv
apps/**/*_OUT.txt
apps/**/FALLBACK_ERROR.txt

# Ignore other local runtime artifacts
Temp/

# Generated parser outputs (reproducible; ignored)
apps/repair_order/0_Open_RO/parse_open_ro_log_ro.txt
apps/repair_order/0_Open_RO/parse_open_ro_log_mva.txt

# Claude Code session data
.claude/

# Test artifacts in root directory
/test_output.txt
/validation_output.txt
/*_output.txt
